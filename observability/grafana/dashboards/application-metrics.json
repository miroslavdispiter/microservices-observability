{
  "id": null,
  "uid": "travelplanner-app-metrics",
  "title": "TravelPlannerApp - Application Metrics",
  "description": "RED metrike za WebApiService (HTTP) + custom business metrike i .NET runtime metrike za UserService/TravelService/SharingService, prikupljene preko OpenTelemetry -> Prometheus.",
  "tags": ["travelplannerapp", "observability", "application-metrics"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Pregled",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Servisi dostupni (targets up)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "targets": [
        { "expr": "sum(up{job=~\"webapi-service|user-service|travel-service|sharing-service\"})", "legendFormat": "up" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "green", "value": 4 }
            ]
          },
          "max": 4,
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "graphMode": "none",
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Gateway (WebApiService) - HTTP request rate po ruti",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count[1m])) by (http_route, http_response_status_code)",
          "legendFormat": "{{http_route}} [{{http_response_status_code}}]"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Gateway (WebApiService) - p95 trajanje HTTP zahteva po ruti",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket[5m])) by (le, http_route))",
          "legendFormat": "{{http_route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Gateway (WebApiService) - stopa gresaka (5xx)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{http_response_status_code=~\"5..\"}[5m]))",
          "legendFormat": "5xx / sec"
        },
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count[5m]))",
          "legendFormat": "ukupno / sec"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "row",
      "title": "UserService - business metrike",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "UserService - operacije / sec po tipu i ishodu",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "targets": [
        {
          "expr": "sum(rate(user_service_operations_total[1m])) by (operation, result)",
          "legendFormat": "{{operation}} - {{result}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "UserService - neuspesne prijave (login failures) / 5min",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "targets": [
        {
          "expr": "sum(increase(user_service_login_failures_total[5m]))",
          "legendFormat": "login failures"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "UserService - p95 trajanje operacije (ms)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(user_service_operation_duration_ms_bucket[5m])) by (le, operation))",
          "legendFormat": "{{operation}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 10,
      "type": "row",
      "title": "TravelService - business metrike",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "TravelService - operacije / sec po entitetu i operaciji",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "sum(rate(travel_service_operations_total[1m])) by (entity, operation)",
          "legendFormat": "{{entity}} - {{operation}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "TravelService - stopa gresaka po entitetu",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "sum(rate(travel_service_operations_total{result=\"failure\"}[5m])) by (entity)",
          "legendFormat": "{{entity}} - failure/sec"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "TravelService - p95 trajanje operacije po entitetu (ms)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 40 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(travel_service_operation_duration_ms_bucket[5m])) by (le, entity))",
          "legendFormat": "{{entity}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 14,
      "type": "row",
      "title": "SharingService - business metrike",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 48 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "SharingService - operacije / sec po tipu i ishodu",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 49 },
      "targets": [
        {
          "expr": "sum(rate(sharing_service_operations_total[1m])) by (operation, result)",
          "legendFormat": "{{operation}} - {{result}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "SharingService - pristupi deljenim linkovima (validan/nevalidan)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 49 },
      "targets": [
        {
          "expr": "sum(rate(sharing_service_token_access_total[1m])) by (result)",
          "legendFormat": "{{result}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "id": 17,
      "type": "row",
      "title": ".NET Runtime metrike (GC, thread pool)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 57 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "GC heap size po servisu i generaciji",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 58 },
      "targets": [
        {
          "expr": "process_runtime_dotnet_gc_heap_size_bytes",
          "legendFormat": "{{service}} - gen {{generation}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "Thread pool - broj thread-ova po servisu",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 58 },
      "targets": [
        {
          "expr": "process_runtime_dotnet_thread_pool_threads_count",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    }
  ]
}
